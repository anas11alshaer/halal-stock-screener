# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key(s) for image analysis
# Option 1: Single key
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: Multiple keys (comma-separated) for higher quota
# Each key adds 1000 requests/day with gemini-2.5-flash-lite
# GEMINI_API_KEYS=key1,key2,key3

# Musaffa.com credentials (optional, required to unlock ETF compliance data)
MUSAFFA_EMAIL=your_musaffa_email_here
MUSAFFA_PASSWORD=your_musaffa_password_here

# Cache TTL in hours (default: 24)
CACHE_TTL_HOURS=24

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
